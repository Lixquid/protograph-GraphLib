/// Ensures `String` is at least `Length` characters long, inserting
/// `PadCharacter` at the start of the string until it is long enough.
module PadStart

in String: string
in Length: int
in PadCharacter: char

out this: string

where PadCharacter->ToString_Char->MultiplyString(
	Length - String->StringLength
)->ConcatenateString(String)
